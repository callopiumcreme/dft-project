# Public site URL (used in metadata, sitemap, OG, etc)
NEXT_PUBLIC_SITE_URL=https://dft-project.com

# Resend email (contact form). Without it, contact form logs to console.
RESEND_API_KEY=
CONTACT_FROM="DFT <hello@dft-project.com>"
CONTACT_TO=hello@dft-project.com

