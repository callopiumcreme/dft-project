# =============================================================================
# DFT Project — .env.sample
# Copia in .env e sostituisci i valori "changeme"
# NEVER committare .env (già in .gitignore)
# =============================================================================

# --- Database (PostgreSQL 16) -------------------------------------------------
POSTGRES_DB=dft
POSTGRES_USER=dft
POSTGRES_PASSWORD=changeme

# --- Backend (FastAPI) --------------------------------------------------------
# Genera con: openssl rand -hex 32
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
ENVIRONMENT=development

# --- Frontend (Next.js + NextAuth) -------------------------------------------
NEXTAUTH_URL=http://localhost:3000
# Genera con: openssl rand -hex 32
NEXTAUTH_SECRET=changeme-generate-with-openssl-rand-hex-32
NEXT_PUBLIC_API_URL=/api

# --- Opzionale: Sentry -------------------------------------------------------
# SENTRY_DSN=

# --- Opzionale: Email (NextAuth magic link) ----------------------------------
# EMAIL_SERVER_HOST=smtp.example.com
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_USER=user@example.com
# EMAIL_SERVER_PASSWORD=
# EMAIL_FROM=noreply@example.com
