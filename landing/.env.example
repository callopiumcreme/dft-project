# Public site URL (used in metadata, sitemap, OG, etc)
NEXT_PUBLIC_SITE_URL=https://dft-project.com

# Resend email (contact form). Without it, contact form logs to console.
RESEND_API_KEY=
CONTACT_FROM="DFT <hello@dft-project.com>"
CONTACT_TO=hello@dft-project.com

# Optional: Umami self-hosted analytics
# NEXT_PUBLIC_UMAMI_SRC=https://umami.example.com/script.js
# NEXT_PUBLIC_UMAMI_ID=00000000-0000-0000-0000-000000000000

# Backend API (FastAPI) — server-only. Default localhost dev.
BACKEND_URL=http://localhost:18000

# JWT secret — MUST match backend SECRET_KEY for jose.jwtVerify in middleware
JWT_SECRET=change-me-must-match-backend-secret
